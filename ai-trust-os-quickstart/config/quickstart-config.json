{
  "name": "AI Trust OS Quick Start",
  "version": "1.0.0",
  "description": "Production-ready AI governance infrastructure for AWS Bedrock",
  "aws": {
    "regions": {
      "primary": "us-east-1",
      "supported": [
        "us-east-1",
        "us-west-2",
        "eu-west-1",
        "ap-southeast-2",
        "ap-southeast-1"
      ]
    },
    "services": {
      "bedrock": {
        "enabled": true,
        "models": [
          "anthropic.claude-3-sonnet-20240229-v1:0",
          "anthropic.claude-3-haiku-20240307-v1:0",
          "amazon.titan-text-express-v1",
          "meta.llama2-13b-chat-v1"
        ]
      },
      "neptune": {
        "enabled": true,
        "engine_version": "1.3.0.0",
        "instance_classes": {
          "dev": "db.t3.medium",
          "staging": "db.r6g.large",
          "prod": "db.r6g.xlarge"
        }
      },
      "opensearch": {
        "enabled": true,
        "engine_version": "OpenSearch_2.11",
        "instance_classes": {
          "dev": "t3.small.search",
          "staging": "m6g.large.search",
          "prod": "r6g.large.search"
        }
      }
    }
  },
  "deployment": {
    "environments": {
      "dev": {
        "vpc_cidr": "10.0.0.0/16",
        "enable_nat_gateway": true,
        "single_nat_gateway": true,
        "enable_vpc_endpoints": true,
        "log_retention_days": 7,
        "backup_retention_days": 1,
        "neptune_deletion_protection": false
      },
      "staging": {
        "vpc_cidr": "10.1.0.0/16",
        "enable_nat_gateway": true,
        "single_nat_gateway": false,
        "enable_vpc_endpoints": true,
        "log_retention_days": 30,
        "backup_retention_days": 7,
        "neptune_deletion_protection": false
      },
      "prod": {
        "vpc_cidr": "10.2.0.0/16",
        "enable_nat_gateway": true,
        "single_nat_gateway": false,
        "enable_vpc_endpoints": true,
        "log_retention_days": 365,
        "backup_retention_days": 35,
        "neptune_deletion_protection": true
      }
    },
    "stack_order": [
      "ai-trust-os-main",
      "ai-trust-os-pillar-1-discovery",
      "ai-trust-os-pillar-2-telemetry",
      "ai-trust-os-pillar-3-posture",
      "ai-trust-os-pillar-4-proof"
    ]
  },
  "features": {
    "guardrails": {
      "enabled": true,
      "content_policies": {
        "violence": "MEDIUM",
        "sexual": "MEDIUM",
        "hate": "MEDIUM",
        "insults": "LOW",
        "misconduct": "MEDIUM",
        "prompt_attack": "HIGH"
      },
      "pii_policies": {
        "email": "BLOCK",
        "phone": "BLOCK",
        "address": "ANONYMIZE",
        "ssn": "BLOCK",
        "credit_card": "BLOCK",
        "bank_account": "BLOCK"
      },
      "topic_policies": [
        {
          "name": "FinancialAdvice",
          "type": "DENY"
        },
        {
          "name": "MedicalAdvice",
          "type": "DENY"
        },
        {
          "name": "LegalAdvice",
          "type": "DENY"
        }
      ]
    },
    "human_review": {
      "enabled": true,
      "trigger_on": ["FinancialAdvice", "MedicalAdvice", "LegalAdvice"],
      "review_timeout_hours": 24,
      "notification_channels": ["sns", "email"]
    },
    "telemetry": {
      "enabled": true,
      "retention_days": 90,
      "sampling_rate": 1.0,
      "capture_prompt_hashes": true,
      "capture_response_hashes": true,
      "capture_token_counts": true,
      "capture_latency": true
    },
    "asset_discovery": {
      "enabled": true,
      "sync_interval_minutes": 5,
      "track_services": [
        "bedrock",
        "sagemaker",
        "lambda",
        "iam"
      ]
    }
  },
  "security": {
    "encryption": {
      "at_rest": {
        "algorithm": "AES-256",
        "kms_key_spec": "SYMMETRIC_DEFAULT",
        "enable_key_rotation": true
      },
      "in_transit": {
        "tls_version": "1.2",
        "enforce_https": true
      }
    },
    "network": {
      "enable_privatelink": true,
      "enable_vpc_lattice": false,
      "allowed_cidr_blocks": [],
      "flow_logs": {
        "enabled": true,
        "retention_days": 30
      }
    },
    "iam": {
      "enable_mfa": true,
      "session_duration_hours": 1,
      "require_external_id": true,
      "permissions_boundary": "arn:aws:iam::aws:policy/AWSLambda_FullAccess"
    }
  },
  "compliance": {
    "frameworks": {
      "nist_ai_rmf": {
        "enabled": true,
        "version": "1.0"
      },
      "iso_42001": {
        "enabled": true,
        "version": "2023"
      },
      "soc2": {
        "enabled": true,
        "type": "Type II"
      }
    },
    "audit_manager": {
      "enabled": true,
      "assessment_frequency": "DAILY"
    },
    "config_rules": {
      "enabled": true,
      "rule_packs": [
        "AWSConformancePack",
        "Operational-Best-Practices"
      ]
    }
  },
  "monitoring": {
    "cloudwatch": {
      "enabled": true,
      "dashboards": [
        "telemetry",
        "guardrails",
        "cost",
        "compliance"
      ],
      "alarms": {
        "high_latency": {
          "threshold": 5000,
          "evaluation_periods": 2
        },
        "high_error_rate": {
          "threshold": 5,
          "evaluation_periods": 3
        },
        "high_guardrail_interventions": {
          "threshold": 10,
          "evaluation_periods": 3
        }
      }
    },
    "sns_topics": {
      "alerts": "ai-trust-os-alerts",
      "notifications": "ai-trust-os-notifications",
      "compliance": "ai-trust-os-compliance"
    }
  },
  "cost_management": {
    "budgets": {
      "monthly_limit_usd": {
        "dev": 500,
        "staging": 2000,
        "prod": 50000
      },
      "alert_thresholds": [50, 80, 100]
    },
    "tags": {
      "required": [
        "Project",
        "Environment",
        "Owner",
        "CostCenter"
      ]
    }
  },
  "lambda_functions": {
    "api_gateway_proxy": {
      "runtime": "python3.11",
      "memory": 512,
      "timeout": 60,
      "vpc_required": true
    },
    "guardrails_reviewer": {
      "runtime": "python3.11",
      "memory": 512,
      "timeout": 300,
      "vpc_required": true
    },
    "model_evaluation": {
      "runtime": "python3.11",
      "memory": 512,
      "timeout": 300,
      "vpc_required": false
    },
    "agent_registry_sync": {
      "runtime": "python3.11",
      "memory": 512,
      "timeout": 300,
      "vpc_required": true,
      "layers": ["gremlinpython"]
    }
  }
}
